{%- set style_blur = {'Clean': 0, 'Glass': 12, 'Dark': 0, 'Glow': 2, 'Neon': 0} -%}

{#-
  theme_css(user, kind) — the card_mod style body for one card.
  kind: 'card'   full themed surface (background, border, shadow, blur)
        'exempt' theme variables only, all chrome stripped
        'chip'   radius/font/shadow/blur, keeps the card's own background
        'chrome' primary-tinted surface (nav bar and friends), 40% blur
-#}
{%- macro theme_css(user, kind) -%}
{%- set u = '<entity_31>' if user == '<entity_31>' else '<entity_32>' -%}
{%- set style = states('input_select.theme_style_' ~ u) -%}
{%- set pal = states('input_select.theme_palette_' ~ u) -%}
{%- set mode_pref = states('input_select.theme_mode_' ~ u) | lower -%}
{%- set modes = [mode_pref] if mode_pref in ['light', 'dark'] else ['dark', 'light'] -%}
{%- set opacity_override = states('input_number.theme_card_opacity_' ~ u) | float(-1) -%}
{%- set blur_override = states('input_number.theme_card_blur_' ~ u) | float(-1) -%}
{%- set colors = palette_colors.get(pal, palette_colors['Indigo']) -%}
{%- set radius = '4px' if style == 'Neon' else '18px' -%}
{%- set font = "'Share Tech Mono', monospace" if style == 'Neon' else 'inherit' -%}
{%- set blur = (style_blur.get(style, 0) if blur_override < 0 else blur_override) | int -%}
{%- if style == 'Neon' %}
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');
{%- endif -%}
{%- for m in modes %}
{%- set sm = style_by_mode[m] %}
{%- set opacity = (sm.opacity_default.get(style, 95) if opacity_override < 0 else opacity_override) | int %}
{%- set card_bg = 'rgba(' ~ sm.card_rgb.get(style, sm.card_rgb_default) ~ ',' ~ ((opacity / 100) | round(2)) ~ ')' %}
{%- if modes | length > 1 %}
@media (prefers-color-scheme: {{ m }}) {
{%- endif %}
ha-card {
  --primary-color: {{ colors.primary }};
  --accent-color: {{ colors.accent }};
{%- if kind in ['card', 'exempt'] %}
  --state-on-color: {{ colors.state_on }};
  --state-off-color: {{ colors.state_off }};
  --success-color: {{ colors.success }};
  --warning-color: {{ colors.warning }};
  --error-color: {{ colors.error }};
  --info-color: {{ colors.info }};
{%- endif %}
{%- if kind != 'exempt' %}
  border-radius: {{ radius }} !important;
{%- endif %}
  font-family: {{ font }} !important;
{%- if kind == 'card' %}
  position: relative;
  overflow: hidden;
  background: {{ card_bg }} !important;
  border: {{ sm.border.get(style, 'none') }} !important;
  box-shadow: {{ sm.shadow.get(style, 'none') }} !important;
{%- elif kind == 'chrome' %}
  position: relative;
  overflow: hidden;
  background: color-mix(in srgb, {{ colors.primary }} 14%, {{ card_bg }}) !important;
  border: {{ sm.border.get(style, 'none') }} !important;
  box-shadow: {{ sm.shadow.get(style, 'none') }} !important;
{%- elif kind == 'chip' %}
  box-shadow: {{ sm.shadow.get(style, 'none') }} !important;
{%- elif kind == 'exempt' %}
  background: none !important;
  backdrop-filter: none !important;
  -webkit-backdrop-filter: none !important;
  box-shadow: none !important;
  border: none !important;
{%- endif %}
{%- if kind in ['card', 'chip'] and blur > 0 %}
  backdrop-filter: blur({{ blur }}px) saturate(1.2);
  -webkit-backdrop-filter: blur({{ blur }}px) saturate(1.2);
{%- elif kind == 'chrome' and blur > 0 %}
  backdrop-filter: blur({{ (blur * 0.4) | round(0) | int }}px) saturate(1.2);
  -webkit-backdrop-filter: blur({{ (blur * 0.4) | round(0) | int }}px) saturate(1.2);
{%- endif %}
}
{%- if modes | length > 1 %}
}
{%- endif %}
{%- endfor %}
{%- if kind == 'exempt' %}
ha-card::before {
  content: none !important;
}
{%- endif %}
{%- endmacro -%}

{#-
  view_background_css(user) — the fixed page-background card's style body:
  the lovelace background plus the Glow style's radial orbs.
-#}
{%- macro view_background_css(user) -%}
{%- set u = '<entity_31>' if user == '<entity_31>' else '<entity_32>' -%}
{%- set style = states('input_select.theme_style_' ~ u) -%}
{%- set pal = states('input_select.theme_palette_' ~ u) -%}
{%- set bg = states('input_text.theme_background_' ~ u) -%}
{%- set mode_pref = states('input_select.theme_mode_' ~ u) | lower -%}
{%- set modes = [mode_pref] if mode_pref in ['light', 'dark'] else ['dark', 'light'] -%}
{%- set glow_active = style == 'Glow' and bg in ['unknown', 'unavailable', 'auto', ''] -%}
{%- for m in modes %}
{%- set sm = style_by_mode[m] %}
{%- set pm = palette_by_mode[m].get(pal, palette_by_mode[m]['Indigo']) %}
{%- if bg == 'none' %}
{%- set page_bg = 'transparent' %}
{%- elif bg.startswith('#') %}
{%- set page_bg = bg %}
{%- elif bg not in ['unknown', 'unavailable', 'auto', ''] %}
{%- set page_bg = "center / cover no-repeat fixed url('/local/themes/backgrounds/" ~ bg ~ "')" %}
{%- elif style == 'Glass' %}
{%- set page_bg = pm.glass_bg %}
{%- elif style in sm.bg_fallback %}
{%- set page_bg = sm.bg_fallback[style] %}
{%- else %}
{%- set page_bg = pm.surface %}
{%- endif %}
{%- if modes | length > 1 %}
@media (prefers-color-scheme: {{ m }}) {
{%- endif %}
ha-card {
  background: {{ page_bg }} !important;
}
{%- if glow_active %}
ha-card::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(140% 120% at 108% -8%, {{ pm.glow1 }} 0%, transparent 62%),
    radial-gradient(130% 116% at -8% 108%, {{ pm.glow2 }} 0%, transparent 62%),
    radial-gradient(125% 112% at 50% 132%, {{ pm.glow3 }} 0%, transparent 66%);
  mix-blend-mode: {{ sm.glow_blend }};
  opacity: {{ sm.glow_opacity }};
}
{%- endif %}
{%- if modes | length > 1 %}
}
{%- endif %}
{%- endfor %}
{%- endmacro -%}

{#-
  theme_value(account, prop) — single resolved values for the Appearance
  page (labels, picker grids). `account` is a literal account name, NOT the
  card-mod `user` variable — non-card_mod templates don't receive it.
  prop: 'primary' | 'card_opacity' | 'card_blur' | 'account'
  For mode-dependent defaults, a fixed mode resolves exactly; System
  displays the dark-mode default.
-#}
{%- macro theme_value(account, prop) -%}
{%- set u = '<entity_31>' if account == '<entity_31>' else '<entity_32>' -%}
{%- set style = states('input_select.theme_style_' ~ u) -%}
{%- if prop == 'account' -%}
{{- u -}}
{%- elif prop == 'primary' -%}
{{- palette_colors.get(states('input_select.theme_palette_' ~ u), palette_colors['Indigo']).primary -}}
{%- elif prop == 'card_opacity' -%}
{%- set mode_pref = states('input_select.theme_mode_' ~ u) | lower -%}
{%- set m = mode_pref if mode_pref in ['light', 'dark'] else 'dark' -%}
{%- set override = states('input_number.theme_card_opacity_' ~ u) | float(-1) -%}
{{- (style_by_mode[m].opacity_default.get(style, 95) if override < 0 else override) | int -}}
{%- elif prop == 'card_blur' -%}
{%- set override = states('input_number.theme_card_blur_' ~ u) | float(-1) -%}
{{- (style_blur.get(style, 0) if override < 0 else override) | int -}}
{%- endif -%}
{%- endmacro -%}
